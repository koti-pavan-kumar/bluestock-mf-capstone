# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyc

# Virtual environments
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# SQLite database (can exceed GitHub's recommended file size --
# track schema.sql + instructions instead, per project guidelines)
data/db/*.db

# Power BI / Tableau workbooks can be large binary files; track only
# if under GitHub limits, otherwise keep local + share exported PDFs
# dashboard/*.pbix

# Environment variables / secrets
.env

# Raw live-fetch outputs from mfapi.in (regenerate with live_nav_fetch.py
# rather than committing — keep repo light). Uncomment if you'd rather
# keep these out of version control:
# data/raw/*_nav.csv
# data/raw/*_raw.json
